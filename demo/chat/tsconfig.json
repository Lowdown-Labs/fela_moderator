{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@lowdown/moderate/react": ["../../react/index.ts"],
      "@lowdown/moderate": ["../../reference/validate.d.ts"]
    }
  },
  "include": ["src", "shots.mjs"]
}
